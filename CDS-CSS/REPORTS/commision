<script type="text/javascript">
  function checkDate(){
    var fromDate = new Date(document.getElementById("from_date").value);
    var toDate = new Date(document.getElementById("to_date").value);
    
    if (fromDate > toDate){
      alert("To date must be greater than or equal to From date");
      document.getElementById("to_date").value = '';
      return false;
    }
    return true;
  }

  $('#generateNet').click(function() {
    var brokerId = $("#brokerSelect").val();
    var fromDate = $("#from_date").val();
    var toDate = $("#to_date").val();
    
    if(!brokerId) {
      alert("Please select a broker");
      return false;
    }
    
    if(!fromDate || !toDate) {
      alert("Please select both date fields");
      return false;
    }
    
    showLoading();
    
    $.ajax({
      type: "POST",
      url: "load_net.php",
      data: {
        broker: brokerId,
        fromDate: fromDate,
        toDate: toDate,
        reportType: 'Net'
      },
      success: function(data) {
        hideloading();
        $("#netResults").html(data);
      },
      error: function(xhr, status, error) {
        hideloading();
        console.error("AJAX Error: " + status + " - " + error);
        alert("Error generating report. Please try again.");
      }
    });
  });
</script>
